#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.12"
# dependencies = ["pyserial", "esptool>=4.8.1", "esp-idf-nvs-partition-gen>=0.2.0"]
# ///

"""
Kublet Dev Tool — build, deploy, and manage your Kublet device.

Usage:
    ./tools/dev build [app-name]             # compile firmware
    ./tools/dev deploy <app-name>            # build and send over WiFi OTA
    ./tools/dev deploy <app> --skip-build    # send without rebuilding
    ./tools/dev logs [app-name]              # stream serial logs
    ./tools/dev init                         # flash dev firmware + WiFi creds
    ./tools/dev init --factory               # restore factory firmware
"""

import argparse
import csv
import io
import os
import re
import serial
import shutil
import subprocess
import sys
import time
import urllib.error
import urllib.request
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parent.parent

# ---------------------------------------------------------------------------
# Paths (relative to repo root)
# ---------------------------------------------------------------------------
TOOLS_DIR = REPO_ROOT / "tools"
FIRMWARE_DIR = REPO_ROOT / "firmware"
APPS_DIR = REPO_ROOT / "apps"
ENV_FILE = TOOLS_DIR / ".env"
KUBLET_CONFIG = TOOLS_DIR / ".kublet"
NVS_CSV = TOOLS_DIR / "nvs_wifi.csv"
NVS_BIN = TOOLS_DIR / "nvs_wifi.bin"

DEV_FIRMWARE = FIRMWARE_DIR / "dev_firmware.bin"
DEV_PARTITIONS = FIRMWARE_DIR / "dev_partitions.bin"
FACTORY_FIRMWARE = FIRMWARE_DIR / "firmware.bin"
FACTORY_PARTITIONS = FIRMWARE_DIR / "partitions.bin"
FACTORY_BOOTLOADER = FIRMWARE_DIR / "bootloader.bin"

NVS_PARTITION_SIZE = "0x5000"  # 20 KB, must match partition table

# esptool flash settings
BAUD = "460800"
FLASH_MODE = "dio"
FLASH_FREQ = "40m"


# ---------------------------------------------------------------------------
# TFT_eSPI display config (ST7789, Kublet pin mapping, 40 MHz SPI)
# ---------------------------------------------------------------------------

